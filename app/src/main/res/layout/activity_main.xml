<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/cinza_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="50dp">

    <!-- ===== HEADER ===== -->
    <RelativeLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- LOGO (canto esquerdo) -->
        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo_mini"
            android:background="@android:color/transparent"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <!-- BOTÃO VOLTAR -->
        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="80dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/verde_principal"
            android:background="@android:color/transparent"
            android:layout_toEndOf="@id/btnHome"
            android:layout_marginStart="8dp"
            android:layout_centerVertical="true"/>

        <!-- LOGOUT (canto direito) -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sair"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/cinza_texto"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>

        <!-- BOTÃO PRÓXIMO -->
        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="@color/verde_principal"
            android:background="@android:color/transparent"
            android:layout_toStartOf="@id/btnLogout"
            android:layout_marginEnd="8dp"
            android:layout_centerVertical="true"/>

        <!-- TEXTO CENTRAL -->
        <TextView
            android:id="@+id/tvCompetencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abr/2026"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/verde_principal"
            android:layout_centerInParent="true"/>

    </RelativeLayout>

    <!-- ===== BOTÃO NOVO ===== -->
    <Button
        android:id="@+id/btnNovo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="➕ Novo Lançamento"
        android:backgroundTint="@color/verde_claro"
        android:textColor="@android:color/white"
        android:layout_margin="16dp"/>

    <!-- ===== CARDS ===== -->
    <GridLayout
        android:columnCount="2"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- SALDO EM CAIXA -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saldo em Caixa"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvSaldoCaixa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SALDO PREVISTO -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saldo Previsto"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvSaldoPrevisto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RECEITAS PREVISTAS -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Receitas Previstas"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvReceitasPrevistas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/verde_claro"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DESPESAS PREVISTAS -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Despesas Previstas"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvDespesasPrevistas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/despesa"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RECEITAS REALIZADAS -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Receitas Realizadas"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvReceitasRealizadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/verde_claro"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DESPESAS REALIZADAS -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Despesas Realizadas"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvDespesasRealizadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/despesa"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </GridLayout>

    <!-- ===== HEADER TABELA ===== -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/verde_principal"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Data"
            android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Lançamento"
            android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Valor"
            android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Status"
            android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ações"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- ===== LISTA ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLancamentos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ===== LOADING ===== -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="16dp"/>

</LinearLayout>