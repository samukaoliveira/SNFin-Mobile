<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/cinza_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <RelativeLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/btnPrev"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/tvCompetencia"
            android:text="Abr/2026"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/verde_principal"
            android:layout_centerInParent="true"/>

        <ImageButton
            android:id="@+id/btnNext"
            android:src="@android:drawable/ic_media_next"
            android:background="@android:color/transparent"
            android:layout_toEndOf="@id/tvCompetencia"/>

        <Button
            android:id="@+id/btnLogout"
            android:text="Sair"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/cinza_texto"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>

    <!-- BOTÃO -->
    <Button
        android:id="@+id/btnNovo"
        android:text="➕ Novo Lançamento"
        android:backgroundTint="@color/verde_claro"
        android:textColor="@android:color/white"
        android:layout_margin="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- CARDS -->
    <GridLayout
        android:columnCount="2"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- CARD TEMPLATE -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="8dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Saldo em Caixa"
                    android:textColor="#666"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvSaldoCaixa"
                    android:text="R$ 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/verde_claro"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DUPLICAR PARA OUTROS CARDS -->
        <!-- saldo previsto -->
        <!-- receitas -->
        <!-- despesas -->

    </GridLayout>

    <!-- HEADER DA TABELA -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/verde_principal"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView android:text="Data" android:textColor="@android:color/white" android:layout_weight="1"/>
        <TextView android:text="Lançamento" android:textColor="@android:color/white" android:layout_weight="2"/>
        <TextView android:text="Valor" android:textColor="@android:color/white" android:layout_weight="1"/>
        <TextView android:text="Status" android:textColor="@android:color/white" android:layout_weight="1"/>
        <TextView android:text="Ações" android:textColor="@android:color/white" android:layout_weight="1"/>
    </LinearLayout>

    <!-- LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLancamentos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>